# Copy to devops/.env and fill in. devops/.env is gitignored — never commit it.

# REQUIRED. Signing key for auth tokens. Compose refuses to start without it.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Optional. Leave empty to use the built-in stub insights provider.
OPENROUTER_API_KEY=

# Optional. OpenRouter model used for AI insights.
AI_MODEL=anthropic/claude-sonnet-5

# Host port the app is published on (http://localhost:<port>).
# Note: 8080 is already in use on this machine.
# Ignored when using docker-compose.traefik.yml (no host port is published).
HELSA_HTTP_PORT=3000

# --- Traefik override only (docker-compose.traefik.yml) ---
# Assumes Traefik is already running and attached to the network below.

# REQUIRED with the Traefik override. Domain the app is served on.
HELSA_DOMAIN=

# External Docker network your Traefik instance watches.
TRAEFIK_NETWORK=traefik

# Traefik entrypoint and certificate resolver names, as configured in
# your Traefik instance.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
